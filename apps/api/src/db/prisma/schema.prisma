generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Plan {
  trial
  basic
  pro
}

enum UserRole {
  user
  admin
}

enum AppointmentStatus {
  scheduled
  confirmed
  completed
  cancelled
  no_show
}

enum ChargeStatus {
  pending
  paid
  overdue
  cancelled
}

enum WhatsAppMessageStatus {
  pending
  sent
  failed
}

enum WhatsAppMessageType {
  reminder
  charge
  confirmation
  custom
}

enum ConsorcioParticipantStatus {
  elegivel
  sorteada
}

model User {
  id                    String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                  String    @db.VarChar(255)
  email                 String    @unique @db.VarChar(255)
  passwordHash          String    @map("password_hash") @db.Text
  phone                 String?   @db.VarChar(20)
  role                  UserRole  @default(user)
  plan                  Plan      @default(trial)
  planExpiresAt         DateTime? @map("plan_expires_at") @db.Timestamptz
  stripeCustomerId           String?   @map("stripe_customer_id") @db.VarChar(100)
  whatsappInstanceId         String?   @map("whatsapp_instance_id") @db.VarChar(100)
  resetPasswordToken         String?   @map("reset_password_token") @db.VarChar(255)
  resetPasswordExpiresAt     DateTime? @map("reset_password_expires_at") @db.Timestamptz
  businessName               String?   @map("business_name") @db.VarChar(255)
  businessCategory           String?   @map("business_category") @db.VarChar(100)
  businessInstagram          String?   @map("business_instagram") @db.VarChar(100)
  businessEmail              String?   @map("business_email") @db.VarChar(255)
  businessPhone              String?   @map("business_phone") @db.VarChar(20)
  businessPixKey             String?   @map("business_pix_key") @db.VarChar(255)
  businessAddress            String?   @map("business_address") @db.Text
  workingHours               Json?     @map("working_hours")
  createdAt                  DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt                  DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  clients               Client[]
  services              Service[]
  appointments          Appointment[]
  charges               Charge[]
  whatsappMessages      WhatsAppMessage[]
  notificationsLogs     NotificationsLog[]
  products              Product[]
  productCategories     ProductCategory[]
  consorcioSettings     ConsorcioSettings?
  consorcioParticipants ConsorcioParticipant[]
  consorcioDraws        ConsorcioDraw[]
  consorcioPdfs         ConsorcioPdf[]

  @@map("users")
}

model Client {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  name        String    @db.VarChar(255)
  phone       String    @db.VarChar(20)
  email       String?   @db.VarChar(255)
  notes       String?   @db.Text
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  appointments Appointment[]
  charges     Charge[]
  whatsappMessages WhatsAppMessage[]
  consorcioParticipants ConsorcioParticipant[]

  @@index([userId])
  @@index([phone])
  @@map("clients")
}

model Service {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  name        String   @db.VarChar(255)
  durationMin Int      @default(60) @map("duration_min")
  price       Decimal  @db.Decimal(10, 2)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  appointments Appointment[]

  @@index([userId])
  @@map("services")
}

model Appointment {
  id            String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String            @map("user_id") @db.Uuid
  clientId      String            @map("client_id") @db.Uuid
  serviceId     String            @map("service_id") @db.Uuid
  scheduledAt   DateTime          @map("scheduled_at") @db.Timestamptz
  status        AppointmentStatus @default(scheduled)
  notes         String?           @db.Text
  reminderSent  Boolean           @default(false) @map("reminder_sent")
  createdAt     DateTime          @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime          @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  client  Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  service Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  charges Charge[]
  whatsappMessages WhatsAppMessage[]

  @@index([userId])
  @@index([scheduledAt])
  @@index([status])
  @@map("appointments")
}

model Charge {
  id                     String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId                 String      @map("user_id") @db.Uuid
  appointmentId          String?     @map("appointment_id") @db.Uuid
  clientId               String      @map("client_id") @db.Uuid
  amount                 Decimal     @db.Decimal(10, 2)
  description           String?     @db.Text
  status                 ChargeStatus @default(pending)
  stripePaymentIntentId  String?     @map("stripe_payment_intent_id") @db.VarChar(100)
  stripePixQrcode        String?     @map("stripe_pix_qrcode") @db.Text
  stripePixCopyPaste     String?     @map("stripe_pix_copy_paste") @db.Text
  dueDate                DateTime    @map("due_date") @db.Date
  paidAt                 DateTime?   @map("paid_at") @db.Timestamptz
  createdAt             DateTime    @default(now()) @map("created_at") @db.Timestamptz
  updatedAt             DateTime    @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  appointment Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  client      Client       @relation(fields: [clientId], references: [id], onDelete: Restrict)
  whatsappMessages WhatsAppMessage[]

  @@index([userId])
  @@index([status])
  @@map("charges")
}

model WhatsAppMessage {
  id            String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String                @map("user_id") @db.Uuid
  clientId      String?               @map("client_id") @db.Uuid
  appointmentId String?               @map("appointment_id") @db.Uuid
  chargeId      String?               @map("charge_id") @db.Uuid
  phone         String                @db.VarChar(20)
  message       String                @db.Text
  type          WhatsAppMessageType
  status        WhatsAppMessageStatus @default(pending)
  sentAt        DateTime?             @map("sent_at") @db.Timestamptz
  createdAt     DateTime              @default(now()) @map("created_at") @db.Timestamptz

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  client      Client?      @relation(fields: [clientId], references: [id], onDelete: SetNull)
  appointment Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  charge      Charge?      @relation(fields: [chargeId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@map("whatsapp_messages")
}

model NotificationsLog {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  type      String   @db.VarChar(50)
  payload   Json?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("notifications_log")
}

model Product {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId            String   @map("user_id") @db.Uuid
  name              String   @db.VarChar(255)
  description       String?  @db.Text
  category          String?  @db.VarChar(100)
  price             Decimal  @db.Decimal(10, 2)
  costPrice         Decimal? @map("cost_price") @db.Decimal(10, 2)
  stockQuantity     Int      @map("stock_quantity") @default(0)
  lowStockAlert     Boolean  @map("low_stock_alert") @default(false)
  lowStockThreshold Int?     @map("low_stock_threshold")
  sku               String?  @db.VarChar(100)
  imageUrl          String?  @map("image_url") @db.Text
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("products")
}

model ProductCategory {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  name        String   @db.VarChar(100)
  description String?  @db.Text
  color       String?  @db.VarChar(20)
  icon        String?  @db.VarChar(50)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("product_categories")
}

model ConsorcioSettings {
  userId               String   @id @map("user_id") @db.Uuid
  cycleName            String   @default("Ciclo atual") @map("cycle_name") @db.VarChar(200)
  drawDayOfMonth       Int      @default(10) @map("draw_day_of_month")
  reminderDayOfMonth   Int      @default(20) @map("reminder_day_of_month")
  reminderTime         String   @default("09:00") @map("reminder_time") @db.VarChar(8)
  selectedPdfIds       Json     @default("[]") @map("selected_pdf_ids")
  updatedAt            DateTime @updatedAt @map("updated_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("consorcio_settings")
}

model ConsorcioParticipant {
  id        String                     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String                     @map("user_id") @db.Uuid
  clientId  String                     @map("client_id") @db.Uuid
  status    ConsorcioParticipantStatus @default(elegivel)
  joinedAt  DateTime                   @default(now()) @map("joined_at") @db.Timestamptz

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([userId, clientId])
  @@index([userId])
  @@map("consorcio_participants")
}

model ConsorcioDraw {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId           String   @map("user_id") @db.Uuid
  drawnAt          DateTime @default(now()) @map("drawn_at") @db.Timestamptz
  winnerName       String   @map("winner_name") @db.VarChar(255)
  winnerParticipantId String? @map("winner_participant_id") @db.Uuid
  participantCount Int      @map("participant_count")
  triggeredBy      String   @map("triggered_by") @db.VarChar(20)
  videoUrl         String?  @map("video_url") @db.Text
  /// Vídeo curto em base64 (preview antes de enviar pelo 2º webhook). Opcional.
  videoPreviewBase64 String? @map("video_preview_base64") @db.Text
  videoPreviewMime   String? @map("video_preview_mime") @db.VarChar(100)
  /// true até o webhook de envio (WhatsApp) confirmar sucesso.
  whatsappDispatchPending Boolean @default(false) @map("whatsapp_dispatch_pending")
  /// Retorno do n8n: videoGenerated, whatsappSent, etc.
  n8nAutomation    Json?    @map("n8n_automation")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, drawnAt(sort: Desc)])
  @@map("consorcio_draws")
}

model ConsorcioPdf {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  title       String   @map("title") @db.VarChar(200)
  fileName    String?  @map("file_name") @db.VarChar(255)
  mime        String   @map("mime") @db.VarChar(50)
  /// URL pública após upload via n8n (ex.: MinIO). Novos cadastros usam só isto.
  publicUrl   String?  @map("public_url") @db.Text
  /// Legado: PDF em base64 no banco (cadastros antigos). Novos: null.
  pdfBase64   String?  @map("pdf_base64") @db.Text
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@map("consorcio_pdfs")
}

