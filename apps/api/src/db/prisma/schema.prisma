generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Plan {
  trial
  basic
  pro
}

enum AppointmentStatus {
  scheduled
  confirmed
  completed
  cancelled
  no_show
}

enum ChargeStatus {
  pending
  paid
  overdue
  cancelled
}

enum WhatsAppMessageStatus {
  pending
  sent
  failed
}

enum WhatsAppMessageType {
  reminder
  charge
  confirmation
  custom
}

model User {
  id                    String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                  String    @db.VarChar(255)
  email                 String    @unique @db.VarChar(255)
  passwordHash          String    @map("password_hash") @db.Text
  phone                 String?   @db.VarChar(20)
  plan                  Plan      @default(trial)
  planExpiresAt         DateTime? @map("plan_expires_at") @db.Timestamptz
  stripeCustomerId           String?   @map("stripe_customer_id") @db.VarChar(100)
  whatsappInstanceId         String?   @map("whatsapp_instance_id") @db.VarChar(100)
  resetPasswordToken         String?   @map("reset_password_token") @db.VarChar(255)
  resetPasswordExpiresAt     DateTime? @map("reset_password_expires_at") @db.Timestamptz
  businessName               String?   @map("business_name") @db.VarChar(255)
  workingHours               Json?     @map("working_hours")
  createdAt                  DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt                  DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  clients               Client[]
  services              Service[]
  appointments          Appointment[]
  charges               Charge[]
  whatsappMessages      WhatsAppMessage[]
  notificationsLogs     NotificationsLog[]

  @@map("users")
}

model Client {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  name        String    @db.VarChar(255)
  phone       String    @db.VarChar(20)
  email       String?   @db.VarChar(255)
  notes       String?   @db.Text
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  appointments Appointment[]
  charges     Charge[]
  whatsappMessages WhatsAppMessage[]

  @@index([userId])
  @@index([phone])
  @@map("clients")
}

model Service {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  name        String   @db.VarChar(255)
  durationMin Int      @default(60) @map("duration_min")
  price       Decimal  @db.Decimal(10, 2)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  appointments Appointment[]

  @@index([userId])
  @@map("services")
}

model Appointment {
  id            String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String            @map("user_id") @db.Uuid
  clientId      String            @map("client_id") @db.Uuid
  serviceId     String            @map("service_id") @db.Uuid
  scheduledAt   DateTime          @map("scheduled_at") @db.Timestamptz
  status        AppointmentStatus @default(scheduled)
  notes         String?           @db.Text
  reminderSent  Boolean           @default(false) @map("reminder_sent")
  createdAt     DateTime          @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime          @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  client  Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  service Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  charges Charge[]
  whatsappMessages WhatsAppMessage[]

  @@index([userId])
  @@index([scheduledAt])
  @@index([status])
  @@map("appointments")
}

model Charge {
  id                     String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId                 String      @map("user_id") @db.Uuid
  appointmentId          String?     @map("appointment_id") @db.Uuid
  clientId               String      @map("client_id") @db.Uuid
  amount                 Decimal     @db.Decimal(10, 2)
  description           String?     @db.Text
  status                 ChargeStatus @default(pending)
  stripePaymentIntentId  String?     @map("stripe_payment_intent_id") @db.VarChar(100)
  stripePixQrcode        String?     @map("stripe_pix_qrcode") @db.Text
  stripePixCopyPaste     String?     @map("stripe_pix_copy_paste") @db.Text
  dueDate                DateTime    @map("due_date") @db.Date
  paidAt                 DateTime?   @map("paid_at") @db.Timestamptz
  createdAt             DateTime    @default(now()) @map("created_at") @db.Timestamptz
  updatedAt             DateTime    @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  appointment Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  client      Client       @relation(fields: [clientId], references: [id], onDelete: Restrict)
  whatsappMessages WhatsAppMessage[]

  @@index([userId])
  @@index([status])
  @@map("charges")
}

model WhatsAppMessage {
  id            String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String                @map("user_id") @db.Uuid
  clientId      String?               @map("client_id") @db.Uuid
  appointmentId String?               @map("appointment_id") @db.Uuid
  chargeId      String?               @map("charge_id") @db.Uuid
  phone         String                @db.VarChar(20)
  message       String                @db.Text
  type          WhatsAppMessageType
  status        WhatsAppMessageStatus @default(pending)
  sentAt        DateTime?             @map("sent_at") @db.Timestamptz
  createdAt     DateTime              @default(now()) @map("created_at") @db.Timestamptz

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  client      Client?      @relation(fields: [clientId], references: [id], onDelete: SetNull)
  appointment Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  charge      Charge?      @relation(fields: [chargeId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@map("whatsapp_messages")
}

model NotificationsLog {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  type      String   @db.VarChar(50)
  payload   Json?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("notifications_log")
}
