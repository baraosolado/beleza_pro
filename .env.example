# Banco (local com Docker: docker compose up -d postgres)
# Depois: na pasta apps/api → npm run db:migrate e npm run db:generate
# Teste: GET http://localhost:3001/health/db
#
# IMPORTANTE: a URL deve terminar com /NOME_DO_BANCO (ex.: /beleza_saas).
# Se faltar o nome após :5432, o Prisma pode acusar: Database `(not available)` does not exist.
# Senha com caracteres especiais: use URL-encoding (ex.: @ → %40).
DATABASE_URL=postgresql://beleza:beleza_secret@localhost:5432/beleza_saas

# Auth
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# uazapi
UAZAPI_BASE_URL=
UAZAPI_TOKEN=

# Redis (fila BullMQ: WhatsApp uazapi + lembretes). Opcional em dev — deixe vazio ou comente para não conectar.
# Produção: obrigatório. Local com Docker: docker compose up -d redis
# REDIS_URL=redis://localhost:6379

# n8n — consórcio (dois webhooks):
# 1) DRAW: lista elegíveis → n8n sorteia + gera vídeo → responde ganhadoraNome + videoUrl/videoBase64
# 2) SEND: após a usuária confirmar no SaaS → envia vídeo/mensagem (ex.: WhatsApp)
# N8N_CONSORCIO_DRAW_WEBHOOK_URL=https://seu-n8n/webhook/consorcio-draw
# N8N_CONSORCIO_SEND_WEBHOOK_URL=https://seu-n8n/webhook/consorcio-send
# Upload de revistas (PDF) → n8n salva no MinIO e devolve URL pública (pdfUrl / file / publicUrl)
# N8N_CONSORCIO_PDF_UPLOAD_WEBHOOK_URL=https://seu-n8n/webhook/consorcio-revista-upload
# Revista → qualquer cliente (menu Clientes), JSON com link do PDF + dados do cliente
# N8N_CONSORCIO_REVISTA_CLIENT_WEBHOOK_URL=https://seu-n8n/webhook/consorcio-revista-cliente

# App
NEXT_PUBLIC_API_URL=http://localhost:3001/api
APP_URL=http://localhost:3000
NODE_ENV=development
